@misc{c6f362a1-59ed-4c80-85eb-6b539f6afb03,
  author = {Pratheswaran Hariharan and Haiping Xu and Donghui Yan},
  title = {Mitigating Visual Hallucinations in Multimodal Systems through Retrieval-Augmented Reliability-Aware Inference},
  year = {2026},
  abstract = {This work proposes a retrieval-augmented reliability-aware inference framework for multimodal visual understanding. It retrieves external visual evidence and estimates prediction trustworthiness using similarity strength, class-support agreement, evidence margin, entropy-based uncertainty, and an aggregate reliability score. Experiments on ImageNet-100 report improved accepted prediction accuracy and a lower accepted wrong-answer rate without retraining large multimodal models.}
}

@misc{39dde7af-46f3-47c3-af8b-56e67267dfa7,
  author = {Shahul Es and Jithin James and Luis Espinosa-Anke and Steven Schockaert},
  title = {Ragas: Automated Evaluation of Retrieval Augmented Generation},
  year = {2023},
  abstract = {Ragas introduces a reference-free framework for evaluating retrieval-augmented generation pipelines. Its metric suite assesses retrieval, context, and generation dimensions without relying on ground-truth human annotations.}
}
