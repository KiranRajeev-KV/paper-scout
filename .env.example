# -----------------------------
# Required API Keys / Providers
# -----------------------------

# LLM Provider Key (e.g., Gemini API)
LLM__API_KEY=your_gemini_api_key_here
LLM__PROVIDER=gemini
LLM__MODEL=gemini-2.5-flash
LLM__EMBEDDING_MODEL=gemini-embbeding-001
LLM__MAX_RETRIES=3
LLM__BASE_BACKOFF=500ms
LLM__MAX_BACKOFF=2s
LLM__TIMEOUT=30s

# Optional - increases Semantic Scholar rate limit
APIS__SEMANTIC_SCHOLAR__API_KEY=

# -----------------------------
# Database - Postgres
# -----------------------------
DATABASE__POSTGRES__HOST=localhost
DATABASE__POSTGRES__PORT=5432
DATABASE__POSTGRES__DATABASE=research_agent
DATABASE__POSTGRES__USER=research
DATABASE__POSTGRES__PASSWORD=research123
DATABASE__POSTGRES__SSLMODE=disable
DATABASE__POSTGRES__MAX_CONNECTIONS=10
DATABASE__POSTGRES__MAX_IDLE=5
DATABASE__POSTGRES__CONN_TIMEOUT=30s

# -----------------------------
# Database - Redis
# -----------------------------
DATABASE__REDIS__HOST=localhost
DATABASE__REDIS__PORT=6379
DATABASE__REDIS__DB=0
DATABASE__REDIS__PASSWORD=
DATABASE__REDIS__POOL_SIZE=10

# -----------------------------
# Database - Qdrant
# -----------------------------
DATABASE__QDRANT__HOST=localhost
DATABASE__QDRANT__PORT=6334
DATABASE__QDRANT__COLLECTION=default
DATABASE__QDRANT__API_KEY=

# -----------------------------
# Unstructured API
# -----------------------------
APIS__UNSTRUCTURED__BASEURL=http://localhost:8000
APIS__UNSTRUCTURED__TIMEOUT=60s

# -----------------------------
# Server
# -----------------------------
SERVER__HOST=localhost
SERVER__PORT=8080
SERVER__READ_TIMEOUT=30s
SERVER__WRITE_TIMEOUT=30s

# -----------------------------
# Logging
# -----------------------------
LOGGING__LEVEL=info
LOGGING__FORMAT=console

# -----------------------------
# Pipeline
# -----------------------------
PIPELINE__MAX_PAPERS=50
PIPELINE__MIN_PAPERS_FOR_ANALYSIS=5
PIPELINE__WORKER_POOL_SIZE=10
PIPELINE__JOB_TIMEOUT=60s
PIPELINE__PDF_DOWNLOAD_TIMEOUT=15s
PIPELINE__USE_REDIS_QUEUE=false

# -----------------------------
# Cache (optional)
# -----------------------------
CACHE__DEFAULT_TTL=10m
CACHE__SEARCH_TTL=60m
CACHE__EMBEDDING_TTL=1440m
