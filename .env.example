# -----------------------------
# Required API Keys / Providers
# -----------------------------

# LLM Provider Key (e.g., Gemini API)
LLM_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_EMBEDDING_MODEL=gemini-embbeding-001
LLM_MAX_RETRIES=3
LLM_BASE_BACKOFF=500ms
LLM_MAX_BACKOFF=2s
LLM_TIMEOUT=30s

# Optional - increases Semantic Scholar rate limit
APIS_SEMANTIC_SCHOLAR_API_KEY=

# -----------------------------
# Database - Postgres
# -----------------------------
DATABASE_POSTGRES_HOST=postgres
DATABASE_POSTGRES_PORT=5432
DATABASE_POSTGRES_DATABASE=research_agent
DATABASE_POSTGRES_USER=research
DATABASE_POSTGRES_PASSWORD=research123
DATABASE_POSTGRES_SSLMODE=disable
DATABASE_POSTGRES_MAX_CONNECTIONS=10
DATABASE_POSTGRES_MAX_IDLE=5
DATABASE_POSTGRES_CONN_TIMEOUT=30s

# -----------------------------
# Database - Redis
# -----------------------------
DATABASE_REDIS_HOST=redis
DATABASE_REDIS_PORT=6379
DATABASE_REDIS_DB=0
DATABASE_REDIS_PASSWORD=
DATABASE_REDIS_POOL_SIZE=10

# -----------------------------
# Database - Qdrant
# -----------------------------
DATABASE_QDRANT_HOST=qdrant
DATABASE_QDRANT_PORT=6333
DATABASE_QDRANT_COLLECTION=default
DATABASE_QDRANT_API_KEY=

# -----------------------------
# Unstructured API
# -----------------------------
APIS_UNSTRUCTURED_BASEURL=http://localhost:8000
APIS_UNSTRUCTURED_TIMEOUT=60s

# -----------------------------
# Server
# -----------------------------
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# -----------------------------
# Logging
# -----------------------------
LOGGING_LEVEL=info
LOGGING_FORMAT=console

# -----------------------------
# Pipeline
# -----------------------------
PIPELINE_MAX_PAPERS=50
PIPELINE_MIN_PAPERS_FOR_ANALYSIS=5
PIPELINE_WORKER_POOL_SIZE=10
PIPELINE_JOB_TIMEOUT=60s
PIPELINE_PDF_DOWNLOAD_TIMEOUT=15s
PIPELINE_USE_REDIS_QUEUE=true

# -----------------------------
# Cache (optional)
# -----------------------------
CACHE_DEFAULT_TTL=10m
CACHE_SEARCH_TTL=60m
CACHE_EMBEDDING_TTL=1440m
