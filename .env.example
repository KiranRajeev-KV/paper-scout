# Generation: ollama (default) or gemini.
GENERATION__PROVIDER=ollama
GENERATION__OLLAMA__BASE_URL=http://localhost:11434
GENERATION__OLLAMA__MODEL=qwen3.5:4b-q4_K_M
GENERATION__OLLAMA__TIMEOUT=2m
GENERATION__OLLAMA__KEEP_ALIVE=5m
GENERATION__OLLAMA__CONCURRENCY=1
GENERATION__OLLAMA__THINK=false
GENERATION__OLLAMA__MAX_OUTPUT_TOKENS=1024
GENERATION__OLLAMA__TEMPERATURE=0

# Required only when GENERATION__PROVIDER=gemini.
GENERATION__GEMINI__API_KEY=
GENERATION__GEMINI__MODEL=gemini-2.5-flash
GENERATION__GEMINI__MAX_RETRIES=3
GENERATION__GEMINI__BASE_BACKOFF=500ms
GENERATION__GEMINI__MAX_BACKOFF=2s
GENERATION__GEMINI__TIMEOUT=30s
GENERATION__GEMINI__MAX_OUTPUT_TOKENS=512
GENERATION__GEMINI__REQUESTS_PER_MINUTE=15
GENERATION__GEMINI__REQUESTS_PER_DAY=1000

# Qwen3 embeddings through Ollama.
EMBEDDING__PROVIDER=ollama
EMBEDDING__BASE_URL=http://localhost:11434
EMBEDDING__MODEL=qwen3-embedding:8b
EMBEDDING__TIMEOUT=2m
EMBEDDING__KEEP_ALIVE=0
EMBEDDING__CONCURRENCY=1
EMBEDDING__DIMENSIONS=4096
EMBEDDING__QUERY_INSTRUCTION=Given an academic research topic, retrieve relevant academic-paper abstracts and passages
EMBEDDING__INSTRUCTION_VERSION=qwen3-retrieval-v1
EMBEDDING__INDEXING_VERSION=v1
ACCELERATOR__MAX_CONCURRENT=1

DATABASE__POSTGRES__HOST=localhost
DATABASE__POSTGRES__PORT=5432
DATABASE__POSTGRES__DATABASE=research_agent
DATABASE__POSTGRES__USER=research
DATABASE__POSTGRES__PASSWORD=research123
DATABASE__POSTGRES__SSLMODE=disable
DATABASE__REDIS__HOST=localhost
DATABASE__REDIS__PORT=6379
DATABASE__REDIS__PASSWORD=
DATABASE__REDIS__DB=0
DATABASE__QDRANT__HOST=localhost
DATABASE__QDRANT__PORT=6334
DATABASE__QDRANT__ALIAS=paper_embeddings_current
DATABASE__QDRANT__COLLECTION_PREFIX=paper_embeddings
DATABASE__QDRANT__API_KEY=
DATABASE__QDRANT__USE_TLS=false

APIS__SEMANTIC_SCHOLAR__API_KEY=
APIS__DOCLING__BASE_URL=http://localhost:8000
APIS__DOCLING__REQUEST_TIMEOUT=10m
APIS__DOCLING__DOCUMENT_TIMEOUT=9m
APIS__DOCLING__OCR_BEHAVIOR=fallback
APIS__DOCLING__OUTPUT_FORMAT=md
APIS__DOCLING__CONCURRENCY=1
APIS__DOCLING__VERSION=1.21.0

SERVER__HOST=localhost
SERVER__PORT=8080
SERVER__ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SERVER__SUBMISSION_RATE=0.1
SERVER__SUBMISSION_BURST=2

LOGGING__LEVEL=info
LOGGING__FORMAT=console
LOGGING__DIRECTORY=logs

PIPELINE__WORKER_POOL_SIZE=10
PIPELINE__JOB_TIMEOUT=10m
PIPELINE__PDF_INDEXING_TIMEOUT=10m
PIPELINE__EMBEDDING_BATCH_SIZE=10
PIPELINE__USE_REDIS_QUEUE=true
