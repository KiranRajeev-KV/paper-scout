# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional - increases Semantic Scholar rate limit from 5 req/s to 100 req/s
SEMANTIC_SCHOLAR_API_KEY=

# Database
POSTGRES_USER=research
POSTGRES_PASSWORD=research123
POSTGRES_DB=research_agent

# Redis
REDIS_PASSWORD=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Logging (development, production)
LOG_LEVEL=info
LOG_FORMAT=console

# Pipeline
MAX_PAPERS=50
WORKER_POOL_SIZE=10
